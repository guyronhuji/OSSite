---
import '../styles/site.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { pageHref, withBase, type Locale } from '../lib/i18n';

interface NavItem {
  href: string;
  label: string;
  active?: boolean;
}

interface LanguageLink {
  locale: Locale;
  href: string;
  active: boolean;
}

interface ProfileData {
  name: string;
  title: string;
  affiliation: string;
  email: string;
  phone?: string;
  office?: string;
  orcid?: string;
  cvUrl?: string;
  publicationsPdfUrl?: string;
}

interface UiText {
  skipToContent: string;
  navLabel: string;
  languageLabel: string;
  themeLabel: string;
  themeLight: string;
  themeDark: string;
  contact: string;
  office: string;
  email: string;
  phone: string;
}

interface Props {
  locale: Locale;
  dir: 'ltr' | 'rtl';
  title: string;
  description?: string;
  navItems: NavItem[];
  languageLinks: LanguageLink[];
  profile: ProfileData;
  ui: UiText;
}

const { locale, dir, title, description, navItems, languageLinks, profile, ui } = Astro.props;
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description ?? profile.title} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,700&family=Noto+Sans+Arabic:wght@400;500;600;700&family=Noto+Sans+Hebrew:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem('theme-preference');
          const theme = storedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{ui.skipToContent}</a>

    <div class="site-shell">
      <header class="site-banner">
        <div class="banner-top">
          <LanguageSwitcher label={ui.languageLabel} links={languageLinks} />
          <div class="theme-switcher">
            <label for="theme-select" class="theme-label">{ui.themeLabel}</label>
            <select id="theme-select" class="theme-select" aria-label={ui.themeLabel}>
              <option value="light">{ui.themeLight}</option>
              <option value="dark">{ui.themeDark}</option>
            </select>
          </div>
        </div>

        <div class="banner-brand">
          <a href={pageHref(locale, [])} class="site-name">
            {profile.name}
          </a>
          <p class="site-title">{profile.title}</p>
          <p class="site-affiliation">{profile.affiliation}</p>
        </div>

        <nav class="banner-nav" aria-label={ui.navLabel}>
          <ul role="list">
            {
              navItems.map((item) => (
                <li>
                  <a href={item.href} class:list={['nav-link', { active: item.active }]} aria-current={item.active ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </header>

      <div class="main-column">
        <main id="main-content" class="main-content">
          <slot />
        </main>

        <footer class="site-footer">
          <div class="footer-bar">
            <p class="footer-copy">© {new Date().getFullYear()} {profile.name}</p>
            <nav aria-label={ui.navLabel} class="footer-links">
              <ul role="list">
                {
                  navItems.map((item) => (
                    <li>
                      <a href={item.href}>{item.label}</a>
                    </li>
                  ))
                }
              </ul>
            </nav>
          </div>
        </footer>
      </div>
    </div>
    <script is:inline>
      (() => {
        const select = document.getElementById('theme-select');
        if (!(select instanceof HTMLSelectElement)) return;

        const root = document.documentElement;
        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          select.value = theme;
        };

        let storedTheme = null;
        try {
          storedTheme = localStorage.getItem('theme-preference');
        } catch {}
        const initialTheme = storedTheme === 'dark' ? 'dark' : 'light';
        applyTheme(initialTheme);

        select.addEventListener('change', () => {
          const selected = select.value === 'dark' ? 'dark' : 'light';
          try {
            localStorage.setItem('theme-preference', selected);
          } catch {}
          applyTheme(selected);
        });
      })();
    </script>
  </body>
</html>
