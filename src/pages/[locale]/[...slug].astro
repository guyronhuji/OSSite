---
import { getCollection, getEntry, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { compareByOrderThenTitle, entryHref, isDirectChild, parsePageId } from '../../lib/content';
import { isRtl, localeOrder, pageHref, uiText, withBase } from '../../lib/i18n';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  return pages.flatMap((entry) => {
    const parsed = parsePageId(entry.id);
    if (!parsed) {
      return [];
    }

    return [
      {
        params: {
          locale: parsed.locale,
          slug: parsed.slugParts.length ? parsed.slugParts.join('/') : undefined,
        },
        props: { entry },
      },
    ];
  });
}

const { entry } = Astro.props;
const parsedCurrent = parsePageId(entry.id);

if (!parsedCurrent) {
  throw new Error(`Invalid page id: ${entry.id}`);
}

const locale = parsedCurrent.locale;
const slugParts = parsedCurrent.slugParts;
const dir = isRtl(locale) ? 'rtl' : 'ltr';
const ui = uiText[locale];

const allPages = await getCollection('pages');
const localePages = allPages.filter((page) => parsePageId(page.id)?.locale === locale).sort(compareByOrderThenTitle);

const navItems = localePages
  .filter((page) => {
    const parsed = parsePageId(page.id);
    return page.data.showInNav && Boolean(parsed) && parsed.slugParts.length <= 1;
  })
  .map((page) => {
    const parsed = parsePageId(page.id);
    if (!parsed) {
      return null;
    }

    const href = entryHref(page);
    if (!href) {
      return null;
    }

    return {
      href,
      label: page.data.navTitle ?? page.data.title,
      active: parsed.slugParts.join('/') === slugParts.join('/'),
    };
  })
  .filter((item): item is { href: string; label: string; active: boolean } => item !== null);

const childPages = localePages
  .filter((page) => {
    const parsed = parsePageId(page.id);
    return Boolean(parsed) && isDirectChild(slugParts, parsed.slugParts);
  })
  .map((page) => {
    const href = entryHref(page);
    if (!href) {
      return null;
    }

    return {
      href,
      title: page.data.title,
      description: page.data.excerpt ?? page.data.description,
    };
  })
  .filter((item): item is { href: string; title: string; description?: string } => item !== null);

const languageLinks = localeOrder.map((targetLocale) => {
  const exactMatch = allPages.find((page) => {
    const parsed = parsePageId(page.id);
    return (
      Boolean(parsed) &&
      parsed.locale === targetLocale &&
      parsed.slugParts.join('/') === slugParts.join('/')
    );
  });

  const homeMatch = allPages.find((page) => {
    const parsed = parsePageId(page.id);
    return Boolean(parsed) && parsed.locale === targetLocale && parsed.slugParts.length === 0;
  });

  const href = exactMatch ? entryHref(exactMatch) : homeMatch ? entryHref(homeMatch) : pageHref(targetLocale, []);

  return {
    locale: targetLocale,
    href: href ?? pageHref(targetLocale, []),
    active: targetLocale === locale,
  };
});

const { Content } = await render(entry);

const profileEntry = await getEntry('profile', 'main');
if (!profileEntry) {
  throw new Error('Missing profile content: src/content/profile/main.yaml');
}

const publicationsEntry = await getEntry('publications', 'list');
const publications = (publicationsEntry?.data.items ?? []).slice().sort((a, b) => b.year - a.year);

const profile = profileEntry.data;
const profileImageSrc = withBase('/images/oded-portrait.jpg');
const bookCoverSrc = withBase('/images/race-nation-history-cover.png');

const normalizeOptionalUrl = (url?: string): string | undefined => (url ? withBase(url) : undefined);
const cvUrl = normalizeOptionalUrl(profile.cvUrl);
const publicationsPdfUrl = normalizeOptionalUrl(profile.publicationsPdfUrl);

const pageTitle = `${entry.data.title} | ${profile.name}`;
const pageDescription = entry.data.description ?? entry.data.excerpt ?? profile.title;

const isHome = slugParts.length === 0;
const isPublicationsPage = slugParts.length === 1 && slugParts[0] === 'publications';
const isResearchIndexPage = slugParts.length === 1 && slugParts[0] === 'research';
const isBioPage = slugParts.length === 1 && slugParts[0] === 'bio';
const isContactPage = slugParts.length === 1 && slugParts[0] === 'contact';
const sectionCards = navItems.filter((item) => item.href !== pageHref(locale, []));
const showPageAside = !isResearchIndexPage && (childPages.length > 0 || Boolean(cvUrl) || Boolean(publicationsPdfUrl));

const researchThemeIcons = ['◼', '◷', '✦'];
const researchThemes = childPages.map((child, index) => ({
  ...child,
  icon: researchThemeIcons[index % researchThemeIcons.length],
  accentClass: `theme-accent-${(index % 3) + 1}`,
}));

const publicationGroup = (item: (typeof publications)[number]) => {
  if (item.status === 'forthcoming') return 'forthcoming';
  if (item.type === 'book' || item.type === 'edited_volume') return 'books';
  if (item.type === 'chapter') return 'chapters';
  return 'articles';
};

const publicationTypeLabel = (item: (typeof publications)[number]) => {
  if (item.status === 'forthcoming') return ui.filterForthcoming;
  if (item.type === 'book' || item.type === 'edited_volume') return ui.filterBooks;
  if (item.type === 'chapter') return ui.filterChapters;
  return ui.filterArticles;
};

const timelineItems = [
  { years: '2003-2006', title: 'BA Studies', detail: 'Hebrew University of Jerusalem' },
  { years: '2007-2010', title: 'MA Studies', detail: 'European Forum, Hebrew University (Supervisor: Prof. Dan Diner)' },
  { years: '2011-2015', title: 'DPhil', detail: 'University of Oxford (Supervisor: Prof. Oliver Zimmer)' },
  { years: '2015-2017', title: 'Postdoctoral Fellow', detail: 'Freie Universitat Berlin and Hebrew University' },
  { years: '2017-2019', title: 'Postdoctoral Fellow', detail: 'Hubert H. Humphrey Center, Ben-Gurion University' },
  { years: '2019-2020', title: 'Postdoctoral Fellow', detail: 'CSoC, Ben-Gurion University' },
  { years: '2020-2024', title: 'Lecturer', detail: 'European Forum and Department of International Relations, HUJI' },
  { years: '2024-Present', title: 'Senior Lecturer', detail: 'European Forum and Department of International Relations, HUJI' },
];

const academicProfiles = [
  { label: 'ORCID', href: 'https://orcid.org/0000-0002-4399-7889', icon: 'ID' },
  { label: 'Google Scholar', href: 'https://scholar.google.com/scholar?q=Oded+Y.+Steinberg', icon: 'GS' },
  { label: 'Academia.edu', href: 'https://huji.academia.edu/OdedSteinberg', icon: 'AC' },
  { label: 'ResearchGate', href: 'https://www.researchgate.net/search/publication?q=Oded%20Y.%20Steinberg', icon: 'RG' },
  { label: 'HUJI Profile', href: 'https://odedsteinberg.huji.ac.il/', icon: 'HU' },
];
---

<SiteLayout
  locale={locale}
  dir={dir}
  title={pageTitle}
  description={pageDescription}
  navItems={navItems}
  languageLinks={languageLinks}
  profile={profile}
  ui={ui}
>
  {
    isHome ? (
      <>
        <section class="hero">
          <div>
            <h1>{entry.data.title}</h1>
            {entry.data.description ? <p>{entry.data.description}</p> : null}
            <div class="quick-links" role="list">
              {
                sectionCards.map((item) => (
                  <a class="quick-link" href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
            <div class="interest-tags" role="list" aria-label={ui.researchInterests}>
              {
                profile.interests.map((interest) => (
                  <span class="interest-tag">{interest}</span>
                ))
              }
            </div>
          </div>
          <div class="hero-media">
            <img class="hero-portrait" src={profileImageSrc} alt={ui.profileImageAlt} width="180" height="140" loading="eager" />
            <img class="hero-book" src={bookCoverSrc} alt={ui.bookCoverAlt} width="243" height="361" loading="lazy" />
          </div>
        </section>

        <div class:list={['content-layout', { 'single-column': !showPageAside }]}>
          <article class="prose">
            <Content />
          </article>

          <aside class="side-panel">
            <div class="identity-panel">
              <img class="side-photo" src={profileImageSrc} alt={ui.profileImageAlt} width="180" height="140" loading="lazy" />
              <p class="identity-name">{profile.name}</p>
              <p class="identity-role">{profile.title}</p>
            </div>
            <h2>{ui.contact}</h2>
            {profile.office ? <p><strong>{ui.office}:</strong> {profile.office}</p> : null}
            <p>
              <strong>{ui.email}:</strong> <a href={`mailto:${profile.email}`}>{profile.email}</a>
            </p>
            {profile.phone ? (
              <p>
                <strong>{ui.phone}:</strong> <a href={`tel:${profile.phone}`}>{profile.phone}</a>
              </p>
            ) : null}
            <div class="quick-links">
              {cvUrl ? <a class="quick-link download-link" href={cvUrl}><span aria-hidden="true">⬇</span>{ui.downloadCv}</a> : null}
              {publicationsPdfUrl ? (
                <a class="quick-link download-link" href={publicationsPdfUrl}><span aria-hidden="true">⬇</span>{ui.downloadPublicationsPdf}</a>
              ) : null}
            </div>
          </aside>
        </div>
      </>
    ) : (
      <>
        <header>
          <h1 class="page-title">{entry.data.title}</h1>
          {entry.data.description ? <p class="page-description">{entry.data.description}</p> : null}
        </header>

        <div class:list={['content-layout', { 'single-column': !showPageAside }]}>
          <article class="prose">
            <Content />

            {
              isResearchIndexPage ? (
                <section class="theme-grid" aria-label={ui.researchThemes}>
                  {
                    researchThemes.map((theme) => (
                      <a href={theme.href} class:list={['theme-card', theme.accentClass]}>
                        <span class="theme-icon" aria-hidden="true">{theme.icon}</span>
                        <h3>{theme.title}</h3>
                        {theme.description ? <p>{theme.description}</p> : null}
                      </a>
                    ))
                  }
                </section>
              ) : null
            }

            {
              isBioPage ? (
                <section class="bio-timeline" aria-label={ui.careerTimeline}>
                  <h2>{ui.careerTimeline}</h2>
                  <ol>
                    {
                      timelineItems.map((item) => (
                        <li>
                          <div class="timeline-year">{item.years}</div>
                          <div class="timeline-content">
                            <p class="timeline-title">{item.title}</p>
                            <p>{item.detail}</p>
                          </div>
                        </li>
                      ))
                    }
                  </ol>
                </section>
              ) : null
            }

            {
              isPublicationsPage ? (
                <>
                  <div class="pub-filter" data-pub-filter>
                    <button type="button" class="pub-filter-btn active" data-filter="all">{ui.filterAll}</button>
                    <button type="button" class="pub-filter-btn" data-filter="books">{ui.filterBooks}</button>
                    <button type="button" class="pub-filter-btn" data-filter="articles">{ui.filterArticles}</button>
                    <button type="button" class="pub-filter-btn" data-filter="chapters">{ui.filterChapters}</button>
                    <button type="button" class="pub-filter-btn" data-filter="forthcoming">{ui.filterForthcoming}</button>
                  </div>

                  <ul class="publication-list" role="list" data-publication-list>
                    {
                      publications.map((item) => {
                        const group = publicationGroup(item);
                        return (
                          <li class:list={['publication-item', `type-${group}`, { 'is-forthcoming': item.status === 'forthcoming' }]} data-type={group}>
                            <div class="publication-meta">
                              <span>{item.year}</span>
                              <span>·</span>
                              <span class:list={['pub-badge', group]}>{publicationTypeLabel(item)}</span>
                            </div>
                            <p class="publication-title">{item.title}</p>
                            <p class="publication-details">
                              {item.authors}. {item.venue}
                              {item.details ? ` ${item.details}` : ''}
                              {item.doi ? ` DOI: ${item.doi}` : ''}
                            </p>
                            {item.url ? <p class="publication-details"><a href={item.url} target="_blank" rel="noreferrer">Open link</a></p> : null}
                          </li>
                        );
                      })
                    }
                  </ul>

                  <script is:inline>
                    {`
                      (() => {
                        const root = document.currentScript?.closest('article');
                        if (!root) return;
                        const filterWrap = root.querySelector('[data-pub-filter]');
                        const list = root.querySelector('[data-publication-list]');
                        if (!filterWrap || !list) return;
                        const buttons = Array.from(filterWrap.querySelectorAll('[data-filter]'));
                        const items = Array.from(list.querySelectorAll('[data-type]'));

                        const applyFilter = (value) => {
                          items.forEach((item) => {
                            item.hidden = value !== 'all' && item.dataset.type !== value;
                          });
                          buttons.forEach((btn) => {
                            btn.classList.toggle('active', btn.dataset.filter === value);
                          });
                        };

                        buttons.forEach((btn) => {
                          btn.addEventListener('click', () => applyFilter(btn.dataset.filter || 'all'));
                        });
                      })();
                    `}
                  </script>
                </>
              ) : null
            }

            {
              isContactPage ? (
                <section class="profile-links" aria-label={ui.academicProfiles}>
                  <h2>{ui.academicProfiles}</h2>
                  <div class="profile-link-grid">
                    {
                      academicProfiles.map((link) => (
                        <a href={link.href} target="_blank" rel="noreferrer" class="profile-link-card">
                          <span class="profile-link-icon" aria-hidden="true">{link.icon}</span>
                          <span>{link.label}</span>
                        </a>
                      ))
                    }
                  </div>
                </section>
              ) : null
            }
          </article>

          {
            showPageAside ? (
              <aside class="side-panel">
                <div class="identity-panel">
                  <img class="side-photo" src={profileImageSrc} alt={ui.profileImageAlt} width="180" height="140" loading="lazy" />
                  <p class="identity-name">{profile.name}</p>
                  <p class="identity-role">{profile.title}</p>
                </div>

                {childPages.length > 0 ? (
                  <>
                    <h2>{ui.subpages}</h2>
                    <ul role="list">
                      {
                        childPages.map((child) => (
                          <li>
                            <a href={child.href}>
                              {child.title}
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                  </>
                ) : null}

                <div class="quick-links">
                  {cvUrl ? <a class="quick-link download-link" href={cvUrl}><span aria-hidden="true">⬇</span>{ui.downloadCv}</a> : null}
                  {publicationsPdfUrl ? (
                    <a class="quick-link download-link" href={publicationsPdfUrl}><span aria-hidden="true">⬇</span>{ui.downloadPublicationsPdf}</a>
                  ) : null}
                </div>
              </aside>
            ) : null
          }
        </div>
      </>
    )
  }
</SiteLayout>
